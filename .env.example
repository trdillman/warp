# Warp environment defaults
WARP_DEV=1
WARP_VERBOSE=1
WARP_CACHE_ROOT="${HOME}/.cache/warp"

# Build mode: quick|full
WARP_BUILD_MODE=quick

# Test suite mode: smoke|all
WARP_TEST_SUITE=smoke

# Whether to run pre-commit during maintenance: 1|0
WARP_RUN_PRECOMMIT=0

# Optional CUDA path hints (set as needed)
# CUDA_HOME=/usr/local/cuda
# CUDA_PATH=/usr/local/cuda
# WARP_CUDA_PATH=/usr/local/cuda
